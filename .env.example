# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ── Supabase (auth + database) ─────────────────────────────────────────
# Get from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser, NEVER commit.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI pipeline (Gemini, via @google/genai) ────────────────────────────
# Required by src/services/boardroomService.ts
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — deck/file uploads (app/api/pitches) via an object store.
BLOB_READ_WRITE_TOKEN=
